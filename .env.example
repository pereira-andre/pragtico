# ═══════════════════════════════════════════════════════
# PRAGtico — Configuração de Ambiente
# ═══════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────
# Opções: gemini, openrouter, openai, deepseek
LLM_PROVIDER=openrouter

# OpenRouter — regista em https://openrouter.ai (grátis)
# A key deve começar com sk-or-v1- (copia da página de API keys)
OPENROUTER_API_KEY=sk-or-v1-coloca_a_tua_chave_aqui

# Modelos (gratuitos no OpenRouter)
LLM_MODEL=openrouter/free
EMBEDDING_MODEL=baai/bge-m3

# ── Flask ──────────────────────────────────────────────
FLASK_SECRET_KEY=troca-esta-chave-em-producao
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ── Base de Dados ──────────────────────────────────────
# Local (JSON) — para desenvolvimento sem PostgreSQL
APP_STORAGE_BACKEND=json
RAG_INDEX_BACKEND=json

# PostgreSQL — para produção (descomenta)
# APP_STORAGE_BACKEND=postgres
# RAG_INDEX_BACKEND=pgvector
# DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_portal
# MIGRATE_LOCAL_DATA_ON_START=1

# ── Meteorologia ───────────────────────────────────────
WEATHERAPI_KEY=coloca_a_tua_chave_weatherapi_aqui
WEATHERAPI_LOCATION=Setubal

# ── AIS ────────────────────────────────────────────────
AIS_MAP_CENTER=[38.459517,-8.868642]
AIS_MAP_ZOOM=11
AIS_PORT_LABEL=Porto de Setubal

# ── Embeddings ─────────────────────────────────────────
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUESTS_PER_MINUTE=90
EMBEDDING_REQUESTS_PER_DAY=900
RAG_REINDEX_ON_START=0

# ── Upload ─────────────────────────────────────────────
MAX_UPLOAD_MB=64

# ── Admin (seed automático no primeiro arranque) ──────
ADMIN_EMAIL=admin@porto.pt
ADMIN_PASSWORD=123456
