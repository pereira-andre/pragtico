# ═══════════════════════════════════════════════════════
# PRAGtico — Configuração de Ambiente
# ═══════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────
# Opções: gemini, openrouter, openai, deepseek
# Se não definido, auto-detecta pela API key disponível
LLM_PROVIDER=openrouter

# OpenRouter (recomendado — acesso a 300+ modelos com 1 chave)
OPENROUTER_API_KEY=coloca_a_tua_chave_openrouter_aqui

# Gemini (alternativa — free tier limitado)
# GEMINI_API_KEY=coloca_a_tua_chave_gemini_aqui

# Modelos (ajustar ao provider)
# OpenRouter: google/gemini-2.5-flash, deepseek/deepseek-chat, etc.
# Gemini: gemini-2.5-flash, gemini-2.0-flash-lite
LLM_MODEL=google/gemini-2.5-flash
EMBEDDING_MODEL=google/gemini-embedding-001

# ── Flask ──────────────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=troca-esta-chave-em-producao
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Base de Dados ──────────────────────────────────────
APP_STORAGE_BACKEND=postgres
RAG_INDEX_BACKEND=pgvector
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_portal
MIGRATE_LOCAL_DATA_ON_START=1

# ── Meteorologia ───────────────────────────────────────
WEATHERAPI_KEY=coloca_a_tua_chave_weatherapi_aqui
WEATHERAPI_LOCATION=Setubal

# ── AIS (VesselFinder embed) ──────────────────────────
AIS_MAP_CENTER=[38.459517,-8.868642]
AIS_MAP_ZOOM=11
AIS_VESSELFINDER_NAMES=1
AIS_PORT_LABEL=Porto de Setubal

# ── Embeddings ─────────────────────────────────────────
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUESTS_PER_MINUTE=90
EMBEDDING_REQUESTS_PER_DAY=900
RAG_REINDEX_ON_START=0

# ── Upload ─────────────────────────────────────────────
MAX_UPLOAD_MB=64
