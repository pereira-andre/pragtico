# ═══════════════════════════════════════════════════════
# PRAGtico — Configuração de Ambiente
# Base recomendada para Railway / produção
# ═══════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────
FLASK_ENV=production
FLASK_SECRET_KEY=troca-esta-chave-por-uma-segura-e-longa

# Desenvolvimento local (opcional)
# FLASK_DEBUG=1
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000

# ── Base de Dados e Persistência ───────────────────────
APP_STORAGE_BACKEND=postgres
RAG_INDEX_BACKEND=pgvector

# Em Railway podes apontar para a variável do serviço Postgres.
# Exemplo Railway: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://utilizador:password@host:5432/pragtico
MIGRATE_LOCAL_DATA_ON_START=1

DATABASE_CONNECT_MAX_WAIT_SECONDS=90
DATABASE_CONNECT_RETRY_INTERVAL_SECONDS=2

# Alternativa local simples
# APP_STORAGE_BACKEND=local
# RAG_INDEX_BACKEND=local

# ── Geração LLM ───────────────────────────────────────
# Opções: gemini, openrouter, openai, deepseek
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_FALLBACK_PROVIDER=openrouter
LLM_FALLBACK_MODEL=openrouter/free

# Chaves
OPENAI_API_KEY=sk-coloca_a_tua_chave_openai_aqui
OPENROUTER_API_KEY=sk-or-v1-coloca_a_tua_chave_openrouter_aqui

# Providers opcionais
GEMINI_API_KEY=

# ── Embeddings ────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Railway / produção: embeddings por API
EMBEDDING_LOCAL_ENABLED=0

# Desenvolvimento local (opcional)
# EMBEDDING_LOCAL_ENABLED=1
# EMBEDDING_LOCAL_MODEL=BAAI/bge-m3

EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUESTS_PER_MINUTE=0
EMBEDDING_REQUESTS_PER_DAY=0
EMBEDDING_MAX_RETRIES=6
EMBEDDING_RETRY_WINDOW_SECONDS=60
EMBEDDING_MAX_RETRY_DELAY_SECONDS=15
EMBEDDING_RETRY_PADDING_SECONDS=2

RAG_REINDEX_ON_START=0

# ── Meteorologia e Operação ───────────────────────────
WEATHERAPI_KEY=
WEATHERAPI_LOCATION=Setubal
MANEUVER_CASE_CAPTURE_ENVIRONMENT=1
EXTERNAL_DATA_REFRESH_ENABLED=1

# Refresh periódico das fontes do Instituto Hidrográfico.
WAVE_REFRESH_INTERVAL_SECONDS=3600
WAVE_CACHE_TTL_SECONDS=3600
WAVE_FAILURE_BACKOFF_SECONDS=3600

LOCAL_WARNING_REFRESH_INTERVAL_SECONDS=3600
LOCAL_WARNING_CACHE_TTL_SECONDS=3600
LOCAL_WARNING_FAILURE_BACKOFF_SECONDS=3600
LOCAL_WARNING_ALLOW_INSECURE_SSL_FALLBACK=1

# ── Marés ──────────────────────────────────────────────
# Mantém este CSV fora de `knowledge/` para não ser indexado no RAG.
# TIDE_CSV_PATH=/app/resources/tides/mares.2026.201.9_setubal_troia.csv

# ── AIS ────────────────────────────────────────────────
AIS_MAP_CENTER=[38.459517,-8.868642]
AIS_MAP_ZOOM=11
AIS_PORT_LABEL=Porto de Setubal

# ── WhatsApp Cloud API (teste) ────────────────────────
WHATSAPP_ENABLED=0
WHATSAPP_VERIFY_TOKEN=troca-este-token-de-verificacao
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_ALLOWED_NUMBERS=351962063664
WHATSAPP_DEFAULT_ROLE=admin
WHATSAPP_WELCOME_ENABLED=1
WHATSAPP_WELCOME_MESSAGE=👋 Bem-vindo ao PRAGtico\n\nO teu assistente inteligente para coordenação eficiente de manobras portuárias.\nEm que posso ajudar? 🤖
WHATSAPP_WELCOME_TEMPLATE_NAME=
WHATSAPP_WELCOME_TEMPLATE_LANGUAGE=pt_PT
WHATSAPP_TIMEOUT_SECONDS=15

# URL pública da aplicação
APP_BASE_URL=https://pragtico.up.railway.app

# ── Upload ─────────────────────────────────────────────
MAX_UPLOAD_MB=64

# ── Admin (seed automático no primeiro arranque) ──────
ADMIN_EMAIL=admin@porto.pt
ADMIN_PASSWORD=123456
